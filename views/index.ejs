<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('partials/head') %>
</head>

<body id="page-top" class="regular-navigation">
    <%- include('partials/gtm-noscript') %>
    <div class="master-wrapper">

        <%- include('partials/nav') %>
        <!-- Full-width Bootstrap carousel -->
        <div id="headerwrap" class="nav-trigger"></div>

        <section id="hero" class="no-padding">
            <div id="heroCarousel" class="carousel slide" data-ride="carousel" data-interval="4500">
                <ol class="carousel-indicators">
                    <li data-target="#heroCarousel" data-slide-to="0" class="active"></li>
                    <li data-target="#heroCarousel" data-slide-to="1"></li>
                    <li data-target="#heroCarousel" data-slide-to="2"></li>
                    <li data-target="#heroCarousel" data-slide-to="3"></li>
                </ol>
                <div class="carousel-inner" role="listbox">
                    <div class="item active">
                        <div class="hero-trio">
                            <img src="/assets/img/Sausage on Smoker.webp" class="img-responsive hero-brisket" alt="Sausage on smoker">
                            <img src="/assets/img/Sausage on Tray.webp" class="img-responsive" alt="Sausage on tray">
                            <img src="/assets/img/Pork Tenderloin.webp" class="img-responsive" alt="Pork tenderloin">
                        </div>
                        <div class="carousel-caption">
                            <h3>Welcome to Lando's BBQ</h3>
                        </div>
                    </div>
                    <div class="item">
                        <div class="hero-duo">
                            <img src="/assets/img/Brisket Cater.webp" class="img-responsive" alt="Brisket catering platter">
                            <img src="/assets/img/Turkey Cater.webp" class="img-responsive" alt="Turkey catering platter">
                        </div>
                        <div class="carousel-caption">
                            <h3>Catering platters, ready to serve</h3>
                        </div>
                    </div>
                    <div class="item">
                        <div class="hero-duo">
                            <img src="/assets/img/Full Platter.jpg" class="img-responsive" alt="Full platter">
                            <img src="/assets/img/Brisket, ribs on pit.webp" class="img-responsive" alt="Brisket and ribs on pit">
                        </div>
                        <div class="carousel-caption">
                            <h3>Family platters, fresh off the pit</h3>
                        </div>
                    </div>
                    <div class="item">
                        <div class="hero-trio">
                            <img src="/assets/img/Brisket Slice Image 1.webp" class="img-responsive hero-brisket" alt="Brisket slice">
                            <img src="/assets/img/Beef Rib Image 1.webp" class="img-responsive" alt="Beef rib">
                            <img src="/assets/img/Turkey Image 1.webp" class="img-responsive" alt="Turkey">
                        </div>
                        <div class="carousel-caption">
                            <h3>Classic favorites, smoked to perfection</h3>
                        </div>
                    </div>
                </div>
                <a class="left carousel-control" href="#heroCarousel" role="button" data-slide="prev">
                    <span class="glyphicon glyphicon-chevron-left" aria-hidden="true"></span>
                    <span class="sr-only">Previous</span>
                </a>
                <a class="right carousel-control" href="#heroCarousel" role="button" data-slide="next">
                    <span class="glyphicon glyphicon-chevron-right" aria-hidden="true"></span>
                    <span class="sr-only">Next</span>
                </a>
            </div>
        </section>

        <section id="events-banner" class="text-center" style="padding:28px 15px;background:#f8f3ea;">
            <p style="margin:0;font-size:20px;font-weight:600;letter-spacing:.3px;">
                Catering, Pop-ups, Rodeos, Events. Based in Eagle Mountain UT
            </p>
        </section>

       





        

        <%- include('partials/footer') %>

    </div>

    <%- include('partials/scripts') %>

    <style>
    #hero .item > img{width:100%;height:80vh;object-fit:cover}
    #hero .item .hero-trio{display:flex;height:80vh}
    #hero .item .hero-trio img{width:33.3333%;height:100%;object-fit:cover}
    #hero .item .hero-trio img.hero-brisket{object-position:center 60%}
    #hero .item .hero-duo{display:flex;height:80vh}
    #hero .item .hero-duo img{width:50%;height:100%;object-fit:cover}
    @media (max-width:768px){
        #hero .item .hero-trio{flex-direction:column}
        #hero .item .hero-trio img{width:100%;height:33.3333%}
        #hero .item .hero-duo{flex-direction:column}
        #hero .item .hero-duo img{width:100%;height:50%}
    }
    </style>

     <script type="text/javascript">
     $(document).ready(function(){
         'use strict';
         $('#heroCarousel').carousel({interval:4500, pause:false});
     });
     </script>

</body>

</html>
